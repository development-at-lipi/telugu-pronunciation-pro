# ── Sarvam AI (Primary) ──────────────────────────────────────────
# Sign up at https://console.sarvam.ai to get your key
# Free credits: INR 1,000 on signup
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Google Cloud Speech-to-Text (Fallback) ──────────────────────
# Create a service account at https://console.cloud.google.com
# Enable Speech-to-Text API, download JSON key
# Free tier: 60 minutes/month
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id

# ── App Config ──────────────────────────────────────────────────
FLASK_PORT=5060
LOG_LEVEL=INFO
